{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Debug build",
      "type": "dotnet",
      "task": "build",
      "file": "d:\\projects\\MicrophoneLevelMonitor\\MicrophoneLevelMonitor\\MicrophoneLevelMonitor.csproj",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "close": true
      },
      "hide": true
    },
    {
      "label": "build debug",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/MicrophoneLevelMonitor.sln"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "close": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build release",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/MicrophoneLevelMonitor.sln",
        "--configuration",
        "Release",
        "/p:CompileInstaller=false"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    },
    {
      "label": "build installer",
      "type": "process",
      "command": "dotnet",
      "dependsOn": "build release",
      "dependsOrder": "sequence",
      "args": [
        "msbuild",
        "${workspaceFolder}/MicrophoneLevelMonitor/MicrophoneLevelMonitor.csproj",
        "/target:CompileInstallerOnReleaseBuild",
        "/property:Configuration=Release",
        "/property:CompileInstaller=true"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "close": true
      },
      "group": "build"
    }
  ]
}
